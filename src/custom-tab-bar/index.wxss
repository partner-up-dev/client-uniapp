.tab-bar {
  z-index: 100;

  position: relative;

  background-color: #f3f4e9;

  transition: bottom 0.3s ease;
  padding-bottom: env(safe-area-inset-bottom);
}

.hide {
  display: none;
}

.cont {
  z-index: 0;

  padding: 8px 36px;

  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tab-bar .item {
  height: auto;

  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 4px;

  position: relative;
}

.tab-bar .unselected-item {
  opacity: 0.9;
}

.tab-bar .item .badge {
  position: absolute;
  top: 4px;
  right: 14px;

  width: 8px;
  height: 8px;

  background-color: #ba1a1a;
  color: #ffffff;

  border-radius: 50%;
}

.tab-bar .item .icon-container {
  border-radius: 16px;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 4px 20px;
}

.tab-bar .item .selected-icon-container {
  background-color: #cdeda4;
}

.tab-bar .item .icon {
  width: 22px;
  height: 22px;
}

.tab-bar .item .round-icon {
  border-radius: 50%;
}

.tab-bar .item .txt {
  font-size: 11px;
  line-height: 1.45;
  font-weight: 500;
  letter-spacing: 0.5px;
  color: #1a1c16;
}
